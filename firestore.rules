rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /confessions/{confessionId} {
      allow get: if resource.data.status == 'approved';
      allow list: if false;

      allow create: if request.resource.data.keys().hasOnly([
          'id',
          'recipient',
          'message',
          'sketch',
          'sealedAt',
          'status',
          'demo',
          'createdAt'
        ])
        && request.resource.data.id == confessionId
        && request.resource.data.id is string
        && request.resource.data.id.size() <= 100
        && request.resource.data.recipient is string
        && request.resource.data.recipient.size() > 0
        && request.resource.data.recipient.size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000
        && request.resource.data.sealedAt is string
        && request.resource.data.sealedAt.size() <= 40
        && request.resource.data.status == 'pending'
        && request.resource.data.demo == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.sketch is map
        && request.resource.data.sketch.keys().hasOnly([
          'version',
          'strokes',
          'strokeCount',
          'pointCount'
        ])
        && request.resource.data.sketch.version == 1
        && request.resource.data.sketch.strokes is list
        && request.resource.data.sketch.strokes.size() == request.resource.data.sketch.strokeCount
        && request.resource.data.sketch.strokeCount is int
        && request.resource.data.sketch.strokeCount >= 0
        && request.resource.data.sketch.strokeCount <= 240
        && request.resource.data.sketch.pointCount is int
        && request.resource.data.sketch.pointCount >= 0
        && request.resource.data.sketch.pointCount <= 12000;

      allow update, delete: if false;
    }

    match /confessionIndex/{confessionId} {
      allow get: if true;
      allow list: if request.query.limit != null
        && request.query.limit <= 9;

      allow create, update, delete: if false;
    }
  }
}
